---
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { SITE } from "@consts";
---

<header>
  <Container>
    <div class="flex flex-wrap gap-y-2 justify-between">
      <Link href="/" underline={false}>
        <div class="font-heading font-semibold text-[#e6e6e6]">
          {SITE.NAME}
        </div>
      </Link>
      <nav class="flex gap-1 text-[#a1a1aa] font-mono text-sm">
        <Link href="#skills" underline={false} class="hover:text-[#c1121f] transition-colors">skills</Link>
        <span>/</span>
        <Link href="#projects" underline={false} class="hover:text-[#c1121f] transition-colors">projects</Link>
        <span>/</span>
        <Link href="#contact" underline={false} class="hover:text-[#c1121f] transition-colors">contact</Link>
      </nav>
    </div>
  </Container>
</header>