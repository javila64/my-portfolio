---
import type { CollectionEntry } from "astro:content";

type Props = {
  entry: CollectionEntry<"blog"> | CollectionEntry<"projects"> | CollectionEntry<"work">;
}

const { entry } = Astro.props;
---

<a href={`/${entry.collection}/${entry.slug}`} class="relative group flex flex-nowrap py-4 px-6 mb-4 rounded-2xl border border-stone-100 bg-white shadow-sm hover:shadow-md hover:border-[#c1121f] transition-all duration-300 ease-in-out transform hover:-translate-y-1">
  <div class="flex flex-col flex-1 truncate">
    <div class="font-heading font-bold text-lg text-stone-900 group-hover:text-[#c1121f] transition-colors duration-300">
      {entry.data.title}
    </div>
    <div class="text-sm text-stone-600 mt-1 whitespace-normal">
      {entry.data.description}
    </div>
  </div>
  
  <svg 
    xmlns="http://www.w3.org/2000/svg" 
    viewBox="0 0 24 24"
    class="absolute right-4 top-1/2 -translate-y-1/2 w-5 h-5 fill-none stroke-[#c1121f] stroke-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300 transform group-hover:translate-x-1"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
  </svg>
</a>