---
import { type CollectionEntry, getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { readingTime } from "@lib/utils";
import BackToPrev from "@components/BackToPrev.astro";

export async function getStaticPaths() {
  const projects = (await getCollection("projects"))
    .filter(post => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: project,
  }));
}
type Props = CollectionEntry<"projects">;

const project = Astro.props;
const { Content } = await project.render();
---

<PageLayout title={project.data.title} description={project.data.description}>
  <Container>
    <div class="pt-32 pb-24 max-w-3xl mx-auto w-full px-6">
      
      <div class="mb-8 font-mono text-sm">
        <BackToPrev href="/projects">
          <span class="text-stone-500 hover:text-[#c1121f] transition-colors">> back_to_projects</span>
        </BackToPrev>
      </div>
      
      <div class="flex items-center gap-2 text-sm font-mono text-stone-500 mb-4">
        <FormattedDate date={project.data.date} />
        <span>/</span>
        <span>{readingTime(project.body)}</span>
      </div>
      
      <h1 class="text-4xl font-heading font-extrabold text-stone-900 mb-10">
        {project.data.title}
      </h1>
      
      {/* This prose class is what controls your Markdown styling! */}
      <article class="prose prose-stone max-w-none prose-headings:font-sans prose-headings:font-bold prose-headings:text-stone-900 prose-p:font-sans prose-p:text-stone-600 prose-li:font-sans prose-li:text-stone-600 prose-strong:font-sans prose-strong:text-stone-900 prose-a:font-sans prose-a:text-[#c1121f] prose-code:font-mono prose-code:text-[#c1121f] prose-code:bg-stone-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-md prose-img:rounded-xl prose-img:border prose-img:border-stone-200">
        <Content />
      </article>
      
    </div>
  </Container>
</PageLayout>