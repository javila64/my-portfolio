---
import PageLayout from "@layouts/PageLayout.astro";
import { SITE, HOME } from "@consts";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <section class="flex flex-col gap-10 pt-28 pb-24 max-w-3xl mx-auto w-full px-6">
    
{/* HERO SECTION */}
    <div class="flex flex-col-reverse md:flex-row items-start md:items-center justify-between gap-8 mb-4">
      <div class="flex-1">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 mb-6 rounded-full bg-white border border-stone-200 shadow-sm text-stone-500 text-xs font-mono">
          <span class="w-2 h-2 rounded-full bg-[#f59e0b] animate-pulse"></span>
          Status: Open to internships and part-time work!
        </div>
        <h1 class="font-heading text-5xl font-extrabold tracking-tight text-stone-900 mb-2">
          Jose Avila
        </h1>
        <h2 class="text-xl font-medium text-[#c1121f]">
          Aspiring IT Professional
        </h2>
      </div>
      
      {/* PROFILE IMAGE */}
      <div class="w-32 h-32 md:w-40 md:h-40 flex-shrink-0 border-2 border-stone-200 rounded-3xl overflow-hidden relative shadow-sm transition-all hover:border-[#c1121f] hover:shadow-md transform hover:-translate-y-1">
        <img src="/profile.jpg" alt="Jose Avila" class="absolute inset-0 w-full h-full object-cover" />
      </div>
    </div>

    {/* ABOUT SECTION */}
    <div class="flex flex-col gap-4 text-stone-600 text-lg">
      <p class="leading-relaxed">
        I'm originally from Michoacan, Mexico, but I've spent pretty much my entire life here in San Antonio, TX. Growing up, I've had a natural curiosity and passion for technology, and I've had everything from those old yellowing desktops from the 90s and early 2000s, to modern custom built gaming PCs. 
      </p>
      <p class="leading-relaxed">
        I have experience working as a warehouse associate for UPS and as a Yard Technician at Sunstate Equipment Co. While, my work experinece is in different industries, these jobs have made me into an incredible team player and a calm and composed problem solver.
      </p>
    </div>

    {/* CTA BUTTONS */}
    <div class="flex flex-wrap items-center gap-4 mt-2 text-sm font-semibold">
      <a href="/projects" class="px-6 py-3 rounded-lg bg-[#c1121f] text-white hover:bg-[#a00f1a] shadow-sm transition-all duration-200">
        View Projects
      </a>
      <a href="/resume.pdf" class="px-6 py-3 rounded-lg bg-white border border-stone-200 text-stone-700 hover:border-stone-300 hover:bg-stone-50 shadow-sm transition-all duration-200">
        Download Resume
      </a>
      <a href={`mailto:${SITE.EMAIL}`} class="px-6 py-3 rounded-lg bg-white border border-stone-200 text-stone-700 hover:border-stone-300 hover:bg-stone-50 shadow-sm transition-all duration-200">
        Contact Me
      </a>
    </div>

    {/* SKILLS SECTION */}
    <div id="skills" class="mt-12 scroll-mt-20">
      <h3 class="font-heading text-2xl font-bold text-stone-900 mb-6">Skill Tree</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        
        {/* Systems */}
        {/* Replace the opening div for Systems, Networking, Security, and Dev & Tools with this: */}
        <div class="p-6 bg-white border border-stone-100 rounded-2xl shadow-sm hover:shadow-md transform hover:-translate-y-1 transition-all duration-300">
          <h4 class="text-[#c1121f] font-bold text-sm mb-3 uppercase tracking-wider">Systems</h4>
          <ul class="text-stone-600 text-sm space-y-2.5">
            <li>Linux (Debian, Ubuntu, Kali)</li>
            <li>Windows & Active Directory</li>
            <li>Hardware Assembly & Troubleshooting</li>
          </ul>
        </div>

        {/* Networking */}
        {/* Replace the opening div for Systems, Networking, Security, and Dev & Tools with this: */}
        <div class="p-6 bg-white border border-stone-100 rounded-2xl shadow-sm hover:shadow-md transform hover:-translate-y-1 transition-all duration-300">
          <h4 class="text-[#c1121f] font-bold text-sm mb-3 uppercase tracking-wider">Networking</h4>
          <ul class="text-stone-600 text-sm space-y-2.5">
            <li>Network Topology Design</li>
            <li>Cisco Packet Tracer</li>
            <li>Tailscale</li>
            <li>OSI Model</li>
            <li>TCP/IP</li>
          </ul>
        </div>

        {/* Security */}
        {/* Replace the opening div for Systems, Networking, Security, and Dev & Tools with this: */}
        <div class="p-6 bg-white border border-stone-100 rounded-2xl shadow-sm hover:shadow-md transform hover:-translate-y-1 transition-all duration-300">
          <h4 class="text-[#c1121f] font-bold text-sm mb-3 uppercase tracking-wider">Security</h4>
          <ul class="text-stone-600 text-sm space-y-2.5">
            <li>Splunk & Universal Forwarders</li>
            <li>CompTIA Security+ Concepts</li>
            <li>Access Control</li>
            <li>GPO</li>
          </ul>
        </div>

        {/* Programming & Tools */}
        {/* Replace the opening div for Systems, Networking, Security, and Dev & Tools with this: */}
        <div class="p-6 bg-white border border-stone-100 rounded-2xl shadow-sm hover:shadow-md transform hover:-translate-y-1 transition-all duration-300">
          <h4 class="text-[#c1121f] font-bold text-sm mb-3 uppercase tracking-wider">Dev & Tools</h4>
          <ul class="text-stone-600 text-sm space-y-2.5">
            <li>Python</li>
            <li>Docker & Portainer</li>
            <li>VirtualBox</li>
          </ul>
        </div>

      </div>
    </div>

    {/* PROJECTS SECTION */}
    <div id="projects" class="mt-12 scroll-mt-20">
      <h3 class="font-heading text-2xl font-bold text-stone-900 mb-6">Active Projects</h3>
      <div class="flex flex-col gap-6">
        {projects.map((project) => (
          <div class="bg-white border border-stone-100 p-8 rounded-2xl shadow-sm hover:shadow-md transform hover:-translate-y-1 transition-all duration-300">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-4 gap-4">
              <div>
                <h4 class="font-heading text-xl font-bold text-stone-900 mb-1">{project.data.title}</h4>
                <p class="text-stone-600 text-sm">{project.data.description}</p>
              </div>
              {project.data.status && (
                <span class="px-3 py-1 text-xs font-semibold rounded-full bg-amber-50 text-amber-600 border border-amber-200 whitespace-nowrap">
                  {project.data.status}
                </span>
              )}
            </div>
            
            <div class="mb-5 bg-stone-50 p-4 rounded-xl border border-stone-100">
              <span class="text-stone-900 text-sm font-semibold">Impact: </span>
              <span class="text-stone-600 text-sm">{project.data.impact}</span>
            </div>

            {project.data.tech && (
              <div class="flex flex-wrap gap-2">
                {project.data.tech.map((t) => (
                  <span class="text-xs font-medium text-stone-600 bg-stone-100 border border-stone-200 px-2.5 py-1 rounded-md">
                    {t}
                  </span>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>
    </div>

    {/* Personal Life */}
    <div id="hobbies" class="mt-12 scroll-mt-20">
      <h3 class="font-heading text-2xl font-bold text-stone-900 mb-6">Personal Life</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        
        {/* DESK SETUP IMAGE */}
        <div class="border border-stone-200 rounded-2xl h-56 overflow-hidden relative shadow-sm transition-all hover:border-[#c1121f] hover:shadow-md transform hover:-translate-y-1">
          <img src="/desk.jpg" alt="My Desk Setup" class="absolute inset-0 w-full h-full object-cover" />
        </div>

        <div class="p-6 bg-white border border-stone-100 rounded-2xl shadow-sm hover:shadow-md transform hover:-translate-y-1 transition-all duration-300 flex flex-col justify-center">
          <h4 class="text-[#c1121f] font-bold text-sm mb-3 uppercase tracking-wider">A little bit about me...</h4>
          <p class="text-stone-600 text-sm leading-relaxed mb-4">
            Outside of school and work, I love relaxing at home with my girlfriend and cat. I enjoy watching movies, playing video games, and working on my computer and home lab.
          </p>
          <p class="text-stone-600 text-sm leading-relaxed">
            I also spend a lot of time picking up new hobbies (most of which revolve around tech haha), like web development, home labbing, and most recently, game development!
          </p>
        </div>

      </div>
    </div>
  </section>
</PageLayout>